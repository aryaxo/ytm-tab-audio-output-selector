{
  "manifest_version": 2,
  "name": "YouTube Music Tab Audio Output Selector",
  "version": "1.1.0",
  "description": "Routes YouTube Music tab audio to a selected output device and re-arms after reload when Firefox requires user activation.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "*://music.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://music.youtube.com/*"
      ],
      "js": [
        "content_scripts/content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ytm-tab-audio-output-selector@pepega.wtf",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}